{
  "name": "test-vite-t3",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run lint && vite build",
    "dev": "NODE_ENV=development node --watch --watch-path=src/server --watch-path=src/locales --watch-path=public/openapi --watch-path=.env --watch-path=package.json --import tsx src/server/app.ts",
    "format": "prettier \"**/*\" --write --ignore-unknown",
    "lint": "eslint . && tsc -b",
    "migrate": "prisma migrate dev --name init && prisma generate",
    "seed": "prisma db seed",
    "start": "NODE_ENV=production node dist/server/app.js"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "7.7.0",
    "@prisma/client": "7.7.0",
    "@trpc/server": "11.16.0",
    "argon2": "0.44.0",
    "body-parser": "2.2.2",
    "chalk": "5.6.2",
    "clsx": "2.1.1",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dayjs": "1.11.20",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "helmet": "8.1.0",
    "i18next": "26.0.4",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-http-middleware": "3.9.2",
    "iron-session": "8.0.4",
    "quicktype-core": "23.2.6",
    "react-i18next": "17.0.2",
    "swagger-ui-express": "5.0.1",
    "trpc-to-openapi": "3.2.0",
    "vite-express": "0.22.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@ant-design/icons": "6.1.1",
    "@eslint/js": "9.39.4",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-query": "5.99.0",
    "@tanstack/react-router": "1.168.21",
    "@tanstack/router-plugin": "1.167.22",
    "@trpc/client": "11.16.0",
    "@trpc/tanstack-react-query": "11.16.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/body-parser": "1.19.6",
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/swagger-ui-express": "4.1.8",
    "@vitejs/plugin-react": "6.0.1",
    "antd": "6.3.5",
    "autoprefixer": "10.5.0",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.5.0",
    "postcss": "8.5.9",
    "prettier": "3.8.2",
    "prettier-plugin-packagejson": "3.0.2",
    "prettier-plugin-tailwindcss": "0.7.2",
    "prisma": "7.7.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-head": "3.4.2",
    "rollup": "4.60.1",
    "rollup-plugin-esbuild": "6.2.1",
    "rollup-plugin-node-externals": "8.1.2",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vite": "8.0.8"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "onFail": "error"
    }
  }
}
