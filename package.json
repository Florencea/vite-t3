{
  "name": "vite-t3",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run typecheck && npm run lint && vite build",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev && prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "dev": "node --watch --watch-path=src/server --watch-path=src/locales --watch-path=public/openapi --watch-path=.env --watch-path=package.json --import tsx src/server/app.ts",
    "format": "prettier . --write --ignore-unknown",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "npm run build && node scripts/preview.js",
    "start": "node dist/server/app.js",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@prisma/adapter-libsql": "7.8.0",
    "@prisma/client": "7.8.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.18",
    "@trpc/client": "11.18.0",
    "@trpc/server": "11.18.0",
    "@trpc/tanstack-react-query": "11.18.0",
    "antd": "6.5.1",
    "argon2": "0.44.0",
    "body-parser": "2.3.0",
    "chalk": "5.6.2",
    "clsx": "2.1.1",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dayjs": "1.11.21",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "helmet": "8.3.0",
    "i18next": "26.3.6",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-http-middleware": "3.9.7",
    "iron-session": "8.0.4",
    "quicktype-core": "25.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-head": "3.4.2",
    "react-i18next": "17.0.10",
    "swagger-ui-express": "5.0.1",
    "trpc-to-openapi": "3.3.0",
    "vite-express": "0.22.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@ant-design/icons": "6.3.2",
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/router-plugin": "1.168.20",
    "@types/body-parser": "1.19.6",
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/swagger-ui-express": "4.1.8",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "prettier-plugin-packagejson": "3.0.2",
    "prettier-plugin-tailwindcss": "0.8.1",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.3",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4"
  },
  "engines": {
    "node": "24.18.0"
  }
}
